<Window x:Class="Gramatik.App.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Gramatik Settings"
        Width="700"
        Height="720"
        MinWidth="620"
        MinHeight="620"
        WindowStartupLocation="CenterScreen"
        Background="#F6F7F9">
    <Window.Resources>
        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="#17202A" />
            <Setter Property="FontSize" Value="13" />
        </Style>
        <Style TargetType="Button">
            <Setter Property="MinHeight" Value="32" />
            <Setter Property="Padding" Value="12,4" />
            <Setter Property="Margin" Value="0,0,8,0" />
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="MinHeight" Value="30" />
            <Setter Property="Padding" Value="8,4" />
        </Style>
        <Style TargetType="PasswordBox">
            <Setter Property="MinHeight" Value="30" />
            <Setter Property="Padding" Value="8,4" />
        </Style>
        <Style TargetType="ComboBox">
            <Setter Property="MinHeight" Value="32" />
            <Setter Property="Padding" Value="6,3" />
        </Style>
    </Window.Resources>

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,18">
            <TextBlock Text="Gramatik"
                       FontSize="26"
                       FontWeight="SemiBold" />
            <TextBlock Text="OpenRouter model, API key, and global bindings"
                       Foreground="#5B6470"
                       Margin="0,4,0,0" />
        </StackPanel>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="170" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0"
                           Grid.Column="0"
                           Text="OpenRouter API key"
                           VerticalAlignment="Center"
                           Margin="0,0,16,14" />
                <PasswordBox x:Name="ApiKeyBox"
                             Grid.Row="0"
                             Grid.Column="1"
                             Margin="0,0,0,14" />

                <TextBlock Grid.Row="1"
                           Grid.Column="0"
                           Text="Model"
                           VerticalAlignment="Center"
                           Margin="0,0,16,14" />
                <Grid Grid.Row="1" Grid.Column="1" Margin="0,0,0,14">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <ComboBox x:Name="ModelComboBox"
                              Grid.Column="0" />
                    <Button Grid.Column="1"
                            Content="Refresh"
                            Margin="10,0,0,0"
                            Click="RefreshModels_Click" />
                </Grid>

                <TextBlock Grid.Row="2"
                           Grid.Column="0"
                           Text="Temperature"
                           VerticalAlignment="Center"
                           Margin="0,0,16,14" />
                <Grid Grid.Row="2" Grid.Column="1" Margin="0,0,0,14">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="72" />
                    </Grid.ColumnDefinitions>
                    <Slider x:Name="TemperatureSlider"
                            Grid.Column="0"
                            Minimum="0"
                            Maximum="2"
                            TickFrequency="0.1"
                            IsSnapToTickEnabled="False"
                            VerticalAlignment="Center"
                            ValueChanged="TemperatureSlider_ValueChanged" />
                    <TextBox x:Name="TemperatureTextBox"
                             Grid.Column="1"
                             Margin="10,0,0,0"
                             TextChanged="TemperatureTextBox_TextChanged" />
                </Grid>

                <TextBlock Grid.Row="3"
                           Grid.Column="0"
                           Text="Correct"
                           VerticalAlignment="Center"
                           Margin="0,0,16,14" />
                <Grid Grid.Row="3" Grid.Column="1" Margin="0,0,0,14">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBox x:Name="CorrectHotkeyText"
                             Grid.Column="0"
                             IsReadOnly="True" />
                    <Button Grid.Column="1"
                            Content="Record"
                            Margin="10,0,0,0"
                            Click="RecordCorrect_Click" />
                </Grid>

                <TextBlock Grid.Row="4"
                           Grid.Column="0"
                           Text="Correct + English"
                           VerticalAlignment="Center"
                           Margin="0,0,16,14" />
                <Grid Grid.Row="4" Grid.Column="1" Margin="0,0,0,14">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBox x:Name="TranslateHotkeyText"
                             Grid.Column="0"
                             IsReadOnly="True" />
                    <Button Grid.Column="1"
                            Content="Record"
                            Margin="10,0,0,0"
                            Click="RecordTranslate_Click" />
                </Grid>

                <TextBlock Grid.Row="5"
                           Grid.Column="0"
                           Text="Startup"
                           VerticalAlignment="Center"
                           Margin="0,0,16,14" />
                <CheckBox x:Name="StartWithWindowsCheckBox"
                          Grid.Row="5"
                          Grid.Column="1"
                          Content="Start with Windows"
                          VerticalAlignment="Center"
                          Margin="0,0,0,14" />

                <TextBlock Grid.Row="6"
                           Grid.Column="1"
                           TextWrapping="Wrap"
                           Foreground="#5B6470"
                           Text="Recording accepts keyboard shortcuts and mouse Middle/XButton1/XButton2. Press Esc while recording to cancel." />

                <TextBlock Grid.Row="7"
                           Grid.Column="0"
                           Text="Logs"
                           VerticalAlignment="Top"
                           Margin="0,22,16,0" />
                <Grid Grid.Row="7" Grid.Column="1" Margin="0,22,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="220" />
                    </Grid.RowDefinitions>
                    <StackPanel Grid.Row="0"
                                Orientation="Horizontal"
                                Margin="0,0,0,10">
                        <Button Content="Reload"
                                Click="ReloadLogs_Click" />
                        <Button Content="Open folder"
                                Click="OpenLogsFolder_Click" />
                        <Button Content="Clear"
                                Click="ClearLogs_Click" />
                    </StackPanel>
                    <TextBox x:Name="LogsTextBox"
                             Grid.Row="1"
                             IsReadOnly="True"
                             AcceptsReturn="True"
                             AcceptsTab="True"
                             TextWrapping="NoWrap"
                             VerticalScrollBarVisibility="Auto"
                             HorizontalScrollBarVisibility="Auto"
                             FontFamily="Consolas"
                             FontSize="12" />
                </Grid>
            </Grid>
        </ScrollViewer>

        <Grid Grid.Row="2" Margin="0,18,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <TextBlock x:Name="StatusText"
                       Grid.Column="0"
                       VerticalAlignment="Center"
                       Foreground="#41505F"
                       TextWrapping="Wrap" />
            <StackPanel Grid.Column="1" Orientation="Horizontal">
                <Button Content="Save"
                        Click="Save_Click" />
                <Button Content="Close"
                        Margin="0"
                        Click="Close_Click" />
            </StackPanel>
        </Grid>
    </Grid>
</Window>
